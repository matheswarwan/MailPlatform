PORT=3001
NODE_ENV=development

# PostgreSQL (AWS RDS or local)
DATABASE_URL=postgresql://user:password@localhost:5432/mailflow

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production

# AWS
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# S3 (for logo/asset storage)
S3_BUCKET=mailflow-assets

# SNS Topic ARN for SES events
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:mailflow-ses-events

# App URL (used for preference centre links)
APP_URL=http://localhost:3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
